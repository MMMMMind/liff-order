<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>สั่งอาหาร</title>
<script src="https://static.line-scdn.net/liff/edge/versions/2.22.3/sdk.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap');

:root {
  --green: #06C755;
  --green-dk: #05a847;
  --green-lt: #e8faf0;
  --bg: #f0f0f0;
  --white: #fff;
  --text: #1a1a1a;
  --muted: #888;
  --border: #e8e8e8;
  --radius: 16px;
}
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
body { font-family:'Sarabun',sans-serif; background:var(--bg); min-height:100vh; }

/* ── SCREEN SYSTEM ── */
.screen { display:none; }
.screen.active { display:flex; flex-direction:column; min-height:100vh; }

/* ── TOP BAR ── */
.topbar {
  background:var(--green);
  padding:14px 16px 12px;
  display:flex; align-items:center; gap:10px;
  position:sticky; top:0; z-index:10;
}
.topbar-icon { width:32px; height:32px; border-radius:8px; background:rgba(255,255,255,0.25); display:flex; align-items:center; justify-content:center; font-size:18px; }
.topbar-title { color:#fff; font-size:16px; font-weight:700; flex:1; }
.topbar-sub { color:rgba(255,255,255,0.8); font-size:12px; }

/* ── LOADING ── */
#s-loading { align-items:center; justify-content:center; gap:16px; }
.spinner { width:44px; height:44px; border:4px solid var(--border); border-top-color:var(--green); border-radius:50%; animation:spin .8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }
.load-txt { color:var(--muted); font-size:15px; }

/* ── CATEGORY TABS ── */
.cat-tabs {
  display:flex; gap:8px; padding:12px 16px 4px;
  overflow-x:auto; scrollbar-width:none; background:var(--white);
  border-bottom:0.5px solid var(--border);
}
.cat-tabs::-webkit-scrollbar { display:none; }
.cat-btn {
  padding:6px 14px; border-radius:20px; border:1.5px solid var(--border);
  background:var(--white); color:var(--muted); font-family:'Sarabun',sans-serif;
  font-size:13px; white-space:nowrap; cursor:pointer; transition:all .15s;
}
.cat-btn.on { background:var(--green); border-color:var(--green); color:#fff; font-weight:600; }

/* ── MENU LIST ── */
.menu-body { flex:1; overflow-y:auto; padding:12px 16px; display:flex; flex-direction:column; gap:8px; }
.menu-item {
  background:var(--white); border-radius:var(--radius); border:0.5px solid var(--border);
  padding:10px 12px; display:flex; align-items:center; gap:12px;
  transition:border-color .15s;
}
.menu-item.has-qty { border-color:var(--green); }
.item-img { width:52px; height:52px; border-radius:10px; background:#f5f0eb; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:26px; }
.item-info { flex:1; }
.item-name { font-size:14px; font-weight:600; color:var(--text); }
.item-price { font-size:13px; color:var(--green); font-weight:600; margin-top:2px; }
.item-desc { font-size:11px; color:var(--muted); margin-top:1px; }
.qty-ctrl { display:flex; align-items:center; gap:8px; flex-shrink:0; }
.qty-btn {
  width:28px; height:28px; border-radius:50%; border:1.5px solid var(--border);
  background:var(--white); font-size:16px; font-weight:700; color:var(--muted);
  display:flex; align-items:center; justify-content:center; cursor:pointer;
  transition:all .15s;
}
.qty-btn.plus { background:var(--green); border-color:var(--green); color:#fff; }
.qty-num { font-size:15px; font-weight:700; color:var(--text); min-width:18px; text-align:center; }

/* ── CART BAR ── */
.cart-bar {
  position:sticky; bottom:0; background:var(--white);
  border-top:0.5px solid var(--border); padding:12px 16px;
  display:flex; align-items:center; gap:12px;
}
.cart-bar.hidden { display:none; }
.cart-summary { flex:1; }
.cart-count { font-size:12px; color:var(--muted); }
.cart-total { font-size:18px; font-weight:700; color:var(--text); }
.cart-btn {
  padding:12px 20px; background:var(--green); color:#fff; border:none;
  border-radius:12px; font-family:'Sarabun',sans-serif; font-size:15px;
  font-weight:700; cursor:pointer; white-space:nowrap; transition:background .15s;
}
.cart-btn:active { background:var(--green-dk); transform:scale(0.98); }

/* ── CONFIRM SCREEN ── */
#s-confirm .body { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:12px; }
.confirm-card { background:var(--white); border-radius:var(--radius); border:0.5px solid var(--border); padding:14px 16px; }
.confirm-card .card-title { font-size:13px; color:var(--muted); margin-bottom:10px; font-weight:600; letter-spacing:.3px; }
.order-line { display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:0.5px solid var(--border); font-size:14px; }
.order-line:last-child { border-bottom:none; }
.order-line .name { color:var(--text); }
.order-line .price { color:var(--green); font-weight:600; }
.total-row { display:flex; justify-content:space-between; padding-top:8px; font-size:16px; font-weight:700; }
.total-row .lbl { color:var(--text); }
.total-row .amt { color:var(--green); }
.info-row { display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:0.5px solid var(--border); font-size:14px; }
.info-row:last-child { border-bottom:none; }
.info-row .ico { font-size:18px; width:24px; text-align:center; flex-shrink:0; }
.info-row .lbl { color:var(--muted); font-size:12px; }
.info-row .val { color:var(--text); font-size:14px; }
.notice-box { background:var(--green-lt); border:1px solid #b2ead0; border-radius:12px; padding:12px 14px; display:flex; gap:10px; font-size:13px; color:#1a6640; line-height:1.6; }
.notice-box .ico { font-size:18px; flex-shrink:0; margin-top:1px; }
.confirm-footer { padding:16px; display:flex; flex-direction:column; gap:8px; }
.btn-main { width:100%; padding:15px; background:var(--green); color:#fff; border:none; border-radius:14px; font-family:'Sarabun',sans-serif; font-size:16px; font-weight:700; cursor:pointer; transition:background .15s; }
.btn-main:active { background:var(--green-dk); transform:scale(0.98); }
.btn-main:disabled { background:#bbb; cursor:not-allowed; }
.btn-sec { width:100%; padding:12px; background:transparent; color:var(--muted); border:1px solid var(--border); border-radius:14px; font-family:'Sarabun',sans-serif; font-size:14px; cursor:pointer; }

/* ── SUCCESS ── */
#s-success { align-items:center; justify-content:center; text-align:center; gap:14px; padding:40px 24px; }
.success-ring { width:88px; height:88px; border-radius:50%; background:var(--green-lt); display:flex; align-items:center; justify-content:center; font-size:42px; animation:pop .4s ease; }
@keyframes pop { 0%{transform:scale(.5);opacity:0} 70%{transform:scale(1.1)} 100%{transform:scale(1);opacity:1} }
.success-title { font-size:22px; font-weight:700; color:var(--text); }
.success-sub { font-size:14px; color:var(--muted); line-height:1.8; }
.btn-close { padding:14px 40px; background:var(--green); color:#fff; border:none; border-radius:14px; font-family:'Sarabun',sans-serif; font-size:16px; font-weight:700; cursor:pointer; margin-top:8px; }

/* ── ERROR ── */
#s-error { align-items:center; justify-content:center; text-align:center; gap:12px; padding:40px 24px; }
</style>
</head>
<body>

<!-- LOADING -->
<div id="s-loading" class="screen active">
  <div class="spinner"></div>
  <p class="load-txt">กำลังเชื่อมต่อ LINE...</p>
</div>

<!-- MENU -->
<div id="s-menu" class="screen">
  <div class="topbar">
    <div class="topbar-icon">☕</div>
    <div>
      <div class="topbar-title" id="store-name">ร้านของเรา</div>
      <div class="topbar-sub" id="user-name">กำลังโหลด...</div>
    </div>
  </div>

  <div style="background:var(--white);">
    <div class="cat-tabs" id="cat-tabs"></div>
  </div>

  <div class="menu-body" id="menu-list"></div>

  <div class="cart-bar hidden" id="cart-bar">
    <div class="cart-summary">
      <div class="cart-count" id="cart-count">0 รายการ</div>
      <div class="cart-total" id="cart-total">฿ 0</div>
    </div>
    <button class="cart-btn" onclick="goConfirm()">ดูออเดอร์ →</button>
  </div>
</div>

<!-- CONFIRM -->
<div id="s-confirm" class="screen">
  <div class="topbar">
    <div class="topbar-icon" onclick="goMenu()" style="cursor:pointer;">←</div>
    <div class="topbar-title">ยืนยันออเดอร์</div>
  </div>
  <div class="body">
    <div class="confirm-card">
      <div class="card-title">รายการที่สั่ง</div>
      <div id="confirm-items"></div>
      <div class="total-row">
        <span class="lbl">รวมทั้งหมด</span>
        <span class="amt" id="confirm-total">฿ 0</span>
      </div>
    </div>
    <div class="confirm-card">
      <div class="card-title">ข้อมูลลูกค้า</div>
      <div class="info-row">
        <span class="ico">👤</span>
        <div><div class="lbl">ชื่อ</div><div class="val" id="c-name">-</div></div>
      </div>
      <div class="info-row">
        <span class="ico">🪑</span>
        <div><div class="lbl">โต๊ะ</div><div class="val" id="c-table">-</div></div>
      </div>
      <div class="info-row">
        <span class="ico">⏰</span>
        <div><div class="lbl">เวลาสั่ง</div><div class="val" id="c-time">-</div></div>
      </div>
    </div>
    <div class="notice-box">
      <span class="ico">🔔</span>
      <div>หลังชำระเงินแล้ว <strong>ไม่ต้องทำอะไรเพิ่ม</strong><br>ระบบจะแจ้งยืนยันออเดอร์ใน LINE อัตโนมัติ</div>
    </div>
  </div>
  <div class="confirm-footer">
    <button class="btn-main" id="btn-pay" onclick="submitOrder()">✅ ยืนยัน → ไปชำระเงิน</button>
    <button class="btn-sec" onclick="goMenu()">← แก้ไขรายการ</button>
  </div>
</div>

<!-- SUCCESS -->
<div id="s-success" class="screen">
  <div class="success-ring">✅</div>
  <div class="success-title">บันทึกออเดอร์แล้ว!</div>
  <div class="success-sub">
    กำลังพาไปหน้าชำระเงิน...<br>
    หลังจ่ายเงินเสร็จ LINE จะแจ้งยืนยันให้อัตโนมัติ 🎉
  </div>
</div>

<!-- ERROR -->
<div id="s-error" class="screen">
  <div style="font-size:48px;">⚠️</div>
  <div style="font-size:18px;font-weight:700;color:#c0392b;">เกิดข้อผิดพลาด</div>
  <div style="font-size:14px;color:var(--muted);" id="err-msg">กรุณาลองใหม่</div>
  <button class="btn-main" onclick="location.reload()" style="max-width:240px;">ลองใหม่</button>
</div>

<script>
// ============================================================
//  CONFIG — แก้ค่าตรงนี้
// ============================================================
const CFG = {
  LIFF_ID:      "2009516869-q5LhWGrG",
  STORE_NAME:   "มุมสวนกาแฟสด",
  STORE_ICON:   "☕",
  GPOS_URL:     "https://qr_order-c1og21.th.biot-apps.com/root/qrorder?store_id=S20240623184800000078&table_number=TABLE&checkout_id=",
  // Make.com Webhook ตัวที่ 1: รับ/เก็บออเดอร์ก่อนจ่าย
  MAKE_SAVE_ORDER: "https://hook.us2.make.com/ajvdhlm8adkwys3kv6ki4lobjchlh9es",
};

// ============================================================
//  เมนูร้าน — แก้ตามเมนูจริงของร้าน
// ============================================================
const MENU = [
  { id:1, cat:"กาแฟ", name:"อเมริกาโน่ร้อน",         price:25, emoji:"☕", desc:"" },
  { id:2, cat:"กาแฟ", name:"อเมริกาโน่เย็น",         price:30, emoji:"🧊", desc:"" },
  { id:3, cat:"กาแฟ", name:"อเมริกาโน่ปั่น",         price:35, emoji:"🥤", desc:"" },
  { id:4, cat:"กาแฟ", name:"อเมริกาโน่น้ำผึ้งร้อน",  price:25, emoji:"🍯", desc:"" },
  { id:5, cat:"กาแฟ", name:"อเมริกาโน่น้ำผึ้งเย็น",  price:35, emoji:"🍯", desc:"" },
  { id:6, cat:"กาแฟ", name:"อเมริกาโน่น้ำผึ้งปั่น",  price:40, emoji:"🍯", desc:"" },
];

// ============================================================
let lineUserId = "", displayName = "", tableNumber = "-";
let cart = {}; // { itemId: qty }

// ── INIT ──
async function init() {
  try {
    const params = new URLSearchParams(location.search);
    tableNumber  = params.get("table") || params.get("table_number") || "-";
    document.getElementById("store-name").textContent = CFG.STORE_NAME;

    await liff.init({ liffId: CFG.LIFF_ID });
    if (!liff.isLoggedIn()) { liff.login({ redirectUri: location.href }); return; }

    const p     = await liff.getProfile();
    lineUserId  = p.userId;
    displayName = p.displayName;
    document.getElementById("user-name").textContent = "สวัสดี " + displayName + " 👋";

    buildMenu();
    show("menu");
  } catch(e) {
    document.getElementById("err-msg").textContent = e.message;
    show("error");
  }
}

// ── BUILD MENU ──
function buildMenu() {
  const cats   = [...new Set(MENU.map(m => m.cat))];
  const tabsEl = document.getElementById("cat-tabs");
  const listEl = document.getElementById("menu-list");

  // Category tabs
  tabsEl.innerHTML = ["ทั้งหมด", ...cats].map((c,i) =>
    `<button class="cat-btn ${i===0?'on':''}" onclick="filterCat('${c}',this)">${c}</button>`
  ).join("");

  // Menu items
  listEl.innerHTML = MENU.map(m => `
    <div class="menu-item" id="item-${m.id}">
      <div class="item-img">${m.emoji}</div>
      <div class="item-info">
        <div class="item-name">${m.name}</div>
        <div class="item-price">฿ ${m.price}</div>
        <div class="item-desc">${m.desc}</div>
      </div>
      <div class="qty-ctrl">
        <button class="qty-btn" onclick="setQty(${m.id},-1)" id="minus-${m.id}">−</button>
        <span class="qty-num" id="qty-${m.id}">0</span>
        <button class="qty-btn plus" onclick="setQty(${m.id},1)">+</button>
      </div>
    </div>
  `).join("");
}

function filterCat(cat, el) {
  document.querySelectorAll(".cat-btn").forEach(b => b.classList.remove("on"));
  el.classList.add("on");
  document.querySelectorAll(".menu-item").forEach(item => {
    const id   = parseInt(item.id.replace("item-",""));
    const m    = MENU.find(x => x.id === id);
    item.style.display = (cat === "ทั้งหมด" || m.cat === cat) ? "flex" : "none";
  });
}

function setQty(id, delta) {
  cart[id] = Math.max(0, (cart[id] || 0) + delta);
  if (cart[id] === 0) delete cart[id];
  document.getElementById("qty-" + id).textContent = cart[id] || 0;
  document.getElementById("item-" + id).classList.toggle("has-qty", !!cart[id]);
  updateCartBar();
}

function updateCartBar() {
  const items = cartItems();
  const total = items.reduce((s, i) => s + i.subtotal, 0);
  const count = items.reduce((s, i) => s + i.qty, 0);
  const bar   = document.getElementById("cart-bar");
  bar.classList.toggle("hidden", count === 0);
  document.getElementById("cart-count").textContent = count + " รายการ";
  document.getElementById("cart-total").textContent  = "฿ " + total.toLocaleString();
}

function cartItems() {
  return Object.entries(cart).map(([id, qty]) => {
    const m = MENU.find(x => x.id === parseInt(id));
    return { ...m, qty, subtotal: m.price * qty };
  });
}

// ── CONFIRM ──
function goConfirm() {
  const items = cartItems();
  const total = items.reduce((s,i) => s + i.subtotal, 0);
  const now   = new Date();
  const timeStr = now.toLocaleTimeString("th-TH", { hour:"2-digit", minute:"2-digit" });

  document.getElementById("confirm-items").innerHTML = items.map(i =>
    `<div class="order-line">
      <span class="name">${i.emoji} ${i.name} × ${i.qty}</span>
      <span class="price">฿ ${i.subtotal}</span>
    </div>`
  ).join("");
  document.getElementById("confirm-total").textContent = "฿ " + total.toLocaleString();
  document.getElementById("c-name").textContent  = displayName;
  document.getElementById("c-table").textContent = tableNumber !== "-" ? "โต๊ะ " + tableNumber : "ไม่ระบุโต๊ะ";
  document.getElementById("c-time").textContent  = timeStr + " น.";
  show("confirm");
}

function goMenu() { show("menu"); }

// ── SUBMIT ──
async function submitOrder() {
  const btn   = document.getElementById("btn-pay");
  btn.disabled = true;
  btn.textContent = "⏳ กำลังบันทึก...";

  const items = cartItems();
  const total = items.reduce((s,i) => s + i.subtotal, 0);
  const now   = new Date();

  const payload = {
    lineUserId,
    displayName,
    tableNumber,
    items: items.map(i => ({ name:i.name, qty:i.qty, price:i.price, subtotal:i.subtotal })),
    total,
    timestamp:    now.toISOString(),
    timestampTH:  now.toLocaleString("th-TH", { timeZone:"Asia/Bangkok" }),
  };

  try {
    await fetch(CFG.MAKE_SAVE_ORDER, {
      method:  "POST",
      headers: { "Content-Type":"application/json" },
      body:    JSON.stringify(payload),
    });
  } catch(e) { /* Make.com รับได้แม้ CORS error */ }

  show("success");

  // Redirect ไป GPOS หลัง 1.5 วินาที
  setTimeout(() => {
    const url = CFG.GPOS_URL.replace("TABLE", encodeURIComponent(tableNumber));
    liff.openWindow({ url, external: false });
  }, 1500);
}

// ── UTILS ──
function show(name) {
  document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
  document.getElementById("s-" + name).classList.add("active");
}

init();
</script>
</body>
</html>
